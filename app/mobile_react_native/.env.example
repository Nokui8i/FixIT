# Copy to ".env" in this folder. Values: Firebase Console -> Project settings -> FixIT Mobile (web).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Public FixIT policy URLs (https) and support inbox for mailto: links.
EXPO_PUBLIC_FIXIT_TERMS_URL=
EXPO_PUBLIC_FIXIT_PRIVACY_URL=
EXPO_PUBLIC_FIXIT_REFUNDS_URL=
EXPO_PUBLIC_FIXIT_HELP_CENTER_URL=
EXPO_PUBLIC_FIXIT_SUPPORT_EMAIL=

# Optional but recommended for real address autocomplete suggestions.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe publishable key for mobile SDK initialization (safe public key only).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
