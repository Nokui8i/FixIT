{
  "name": "fixit",
  "private": true,
  "description": "Scripts delegate to the Expo app in app/mobile_react_native",
  "scripts": {
    "start": "npm --prefix app/mobile_react_native start",
    "start:clear": "npm --prefix app/mobile_react_native run start -- -c",
    "android": "npm --prefix app/mobile_react_native run android",
    "ios": "npm --prefix app/mobile_react_native run ios",
    "lint:mobile": "npm --prefix app/mobile_react_native run lint",
    "firebase": "npm --prefix app run firebase",
    "firebase:deploy": "npm --prefix app run firebase:deploy",
    "firebase:deploy:rules": "npm --prefix app run firebase:deploy:rules",
    "fixit:firebase:bootstrap": "powershell -ExecutionPolicy Bypass -File app/complete-fixit-firebase.ps1"
  }
}
